# ── HearthLedger environment ─────────────────────────────────────────────
# Copy this file to .env and fill in values. NEVER commit a real .env.

# Port for the API server (web dev server proxies /api here)
PORT=4000

# Secret used to sign session tokens. Generate one:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change-me-generate-a-random-64-char-hex-string

# 32-byte hex key used to AES-256-GCM encrypt Plaid access tokens at rest.
# Generate one the same way as above. Losing this key means re-linking banks.
TOKEN_ENCRYPTION_KEY=change-me-generate-a-random-64-char-hex-string

# ── Plaid ────────────────────────────────────────────────────────────────
# Sign up free at https://dashboard.plaid.com/signup — Sandbox keys are
# self-serve and instant. Keys live at Dashboard → Developers → Keys.
# Leave these blank to run the app without bank connections (manual accounts
# still work fully).
PLAID_CLIENT_ID=
PLAID_SECRET=
# sandbox | development | production  (keep "sandbox" until Plaid approves
# your production application — see README "Going live with Plaid")
PLAID_ENV=sandbox

# SQLite database file location (created automatically)
DATABASE_PATH=./data/hearthledger.db
